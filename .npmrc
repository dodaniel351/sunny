# Electron + electron-builder pack native modules from a flat node_modules.
# pnpm's default symlinked layout breaks electron-builder's native-dep packing,
# so use a hoisted linker and hoist build/electron tooling to the root.
node-linker=hoisted
shamefully-hoist=true
strict-peer-dependencies=false
# Let better-sqlite3 / keytar rebuild against Electron's ABI on install.
public-hoist-pattern[]=*electron*
public-hoist-pattern[]=*node-gyp*
